# =========================================================================
# =========================================================================
# 1. Load Required Libraries
# =========================================================================
library(tidyverse)
library(plotly)
library(htmlwidgets)
library(RColorBrewer)
library(haven)
options(scipen = 999)
# =========================================================================
# 2. Import Dataset
# =========================================================================
# Import Stata .dta file
Civil_War_and_Primary_Enrollment_firstwar_APSR <- read_dta("Civil War and Primary Enrollment_firstwar_APSR.dta")
