data <- fromJSON(json_text)
# Acessa a tabela de dimensões
df <- data$dimensions
# Seleciona e renomeia colunas para exibição limpa
df_print <- df %>% select(Dimensão = dimension, Análise = content)
# Renderiza a tabela HTML (colapsável pois está dentro do Callout)
kable(df_print, format = "html", table.attr = "class=\"table table-striped table-hover\"")
